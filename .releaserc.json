{
  "branches": ["main"],
  "plugins": [
    ["@semantic-release/commit-analyzer", {
      "preset": "conventionalcommits",
      "releaseRules": [
        {"type": "feat", "release": "minor"},
        {"type": "fix", "release": "patch"},
        {"type": "perf", "release": "patch"},
        {"type": "docs", "release": false},
        {"type": "style", "release": false},
        {"type": "refactor", "release": false},
        {"type": "test", "release": false},
        {"type": "chore", "release": false}
      ]
    }],
    ["@semantic-release/release-notes-generator", {
      "preset": "conventionalcommits"
    }],
    ["@semantic-release/changelog", {
      "changelogFile": "CHANGELOG.md"
    }],
    ["@semantic-release/exec", {
      "prepareCmd": "scripts/bump-version.sh ${nextRelease.version} && ./build.sh"
    }],
    ["@semantic-release/git", {
      "assets": [
        "shared/manifest.base.json",
        "package.json",
        "package-lock.json",
        "CHANGELOG.md",
        "Intention Apple/Intention Safari.xcodeproj/project.pbxproj",
        "Intention Android/app/build.gradle.kts",
        "Intention Chrome/manifest.json",
        "Intention Firefox/manifest.json",
        "Intention Apple/Shared (Extension)/Resources/manifest.json"
      ],
      "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
    }],
    ["@semantic-release/github", {
      "assets": [
        {"path": "build/intention-chrome-v*.zip", "label": "Intention Chrome Extension (v${nextRelease.version})"},
        {"path": "build/intention-firefox-v*.zip", "label": "Intention Firefox Extension (v${nextRelease.version})"},
        {"path": "CHANGELOG.md", "label": "Changelog"}
      ]
    }]
  ]
}
