{
  "name": "intention-extension",
  "version": "0.13.0",
  "private": true,
  "description": "Dev, test, and deployment tooling for the Intention browser extension (Chrome / Firefox / Apple variants). Not a runtime dependency of the extension itself — see .agents/AGENTS.md.",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "sync": "scripts/sync.sh",
    "sync:check": "scripts/sync.sh --check",
    "dev:firefox": "web-ext run --source-dir \"Intention Firefox\"",
    "dev:chrome": "web-ext run --target chromium --source-dir \"Intention Chrome\"",
    "dev:chrome:manual": "node -e \"console.log('\\nLoad the Chrome extension unpacked:\\n  1. Open chrome://extensions\\n  2. Enable Developer mode (top-right)\\n  3. Click \\\"Load unpacked\\\"\\n  4. Select the \\\"Intention Chrome\\\" folder in this repo\\n  5. Reload it from chrome://extensions after any source change\\n')\"",
    "dev:safari": "./build.sh --safari && open \"build/Intention Safari.app\"",
    "dev:ios": "./build.sh --ios",
    "dev:android": "scripts/dev-android.sh",
    "harness": "npx http-server tests/harness -p 8080 -c-1",
    "bump-version": "scripts/bump-version.sh",
    "lint:firefox": "web-ext lint --source-dir=\"Intention Firefox\" --ignore-files env.txt",
    "build": "./build.sh",
    "build:firefox": "web-ext build --source-dir=\"Intention Firefox\" --artifacts-dir=build --overwrite-dest --ignore-files env.txt",
    "sign:firefox": "web-ext sign --source-dir=\"Intention Firefox\" --artifacts-dir=build --channel=unlisted --ignore-files env.txt",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.8",
    "vitest": "^2.1.8",
    "web-ext": "^10.4.0"
  }
}
