{
  "manifest_version": 3,
  "name": "Intention",
  "version": "0.13.1",
  "description": "AI-powered focus gate. Bring your own LLM to coach you past distracting sites.",
  "homepage_url": "https://github.com/MaybeItsAdam/intention",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/*.woff2",
        "coaching.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Intention Settings"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "intention@maybeitssoftware.co.uk",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "browsingActivity",
          "personalCommunications"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "background": {
    "scripts": [
      "providers.js",
      "prompts.js",
      "tracking.js",
      "background.js"
    ]
  }
}
